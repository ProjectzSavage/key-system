local RunService = game:GetService("RunService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local SoundService = game:GetService("SoundService")
local TweenService = game:GetService("TweenService")
local Players = game:GetService("Players")
local Debris = game:GetService("Debris")

local Config = require(ReplicatedStorage:WaitForChild("Modules"):WaitForChild("Config"))

local player = Players.LocalPlayer
local playerStats = player:WaitForChild("Stats")
local Character = script.Parent
local keyboardSoundIdValue = playerStats:WaitForChild("KeyboardSoundId")

local TweenDownInfo = TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
local TweenUpInfo = TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

local RELEASE_GRACE = 0.18
local LoweredParts = {}
local ActiveTweens = {}
local OriginalCFrames = {}
local LastSeenOnKey = {}

local function getKeyboardSoundId()
	return (keyboardSoundIdValue.Value ~= "" and keyboardSoundIdValue.Value) or Config.FallbackKeyboardSound
end

local function playSoundForKey(part)
	local sound = Instance.new("Sound")
	sound.SoundId = getKeyboardSoundId()
	sound.Volume = 1.15
	sound.RollOffMode = Enum.RollOffMode.InverseTapered
	sound.RollOffMinDistance = 6
	sound.RollOffMaxDistance = 55
	sound.PlaybackSpeed = math.random(95, 108) / 100
	sound.Parent = part
	sound:Play()
	Debris:AddItem(sound, 1.5)
end

local function getDownCFrame(part)
	if not OriginalCFrames[part] then
		OriginalCFrames[part] = part.CFrame
	end
	return OriginalCFrames[part] * CFrame.new(0, -Config.LowerAmount, 0)
end

local function getUpCFrame(part)
	if not OriginalCFrames[part] then
		OriginalCFrames[part] = part.CFrame
	end
	return OriginalCFrames[part]
end

local function TweenDown(part: BasePart)
	if ActiveTweens[part] then
		ActiveTweens[part]:Cancel()
	end

	playSoundForKey(part)

	local tween = TweenService:Create(
		part,
		TweenDownInfo,
		{ CFrame = getDownCFrame(part) }
	)

	tween:Play()
	ActiveTweens[part] = tween
	LoweredParts[part] = true
end

local function TweenUp(part: BasePart)
	if ActiveTweens[part] then
		ActiveTweens[part]:Cancel()
	end

	local tween = TweenService:Create(
		part,
		TweenUpInfo,
		{ CFrame = getUpCFrame(part) }
	)

	tween:Play()
	ActiveTweens[part] = tween
	LoweredParts[part] = nil
end

local function Raycast(position: Vector3, params: RaycastParams)
	return workspace:Raycast(position, Vector3.new(0, -4, 0), params)
end

local function GetKeysUnderCharacter()
	local root = Character:FindFirstChild("HumanoidRootPart")
	if not root then return {} end

	local results = {}
	local seen = {}

	local params = RaycastParams.new()
	params.FilterDescendantsInstances = { Character }
	params.FilterType = Enum.RaycastFilterType.Exclude

	local offsets = {
		Vector3.new(1.1, 0, 1.1),
		Vector3.new(-1.1, 0, 1.1),
		Vector3.new(1.1, 0, -1.1),
		Vector3.new(-1.1, 0, -1.1),
		Vector3.new(0, 0, 0),
	}

	local zonesFolder = workspace:FindFirstChild("Zones")
	if not zonesFolder then return {} end

	for _, offset in ipairs(offsets) do
		local result = Raycast(root.Position + offset, params)
		if result and result.Instance and result.Instance:IsDescendantOf(zonesFolder) then
			if not seen[result.Instance] then
				seen[result.Instance] = true
				table.insert(results, result.Instance)
			end
		end
	end

	return results
end

local function UpdateKeys()
	local keys = GetKeysUnderCharacter()
	local current = {}
	local now = tick()

	for _, k in ipairs(keys) do
		current[k] = true
		LastSeenOnKey[k] = now
		if not LoweredParts[k] then
			TweenDown(k)
		end
	end

	for part in pairs(LoweredParts) do
		local lastSeen = LastSeenOnKey[part] or 0
		if not current[part] and (now - lastSeen) > RELEASE_GRACE then
			TweenUp(part)
		end
	end
end

local function SetupZone(zone)
	if not zone:IsA("Folder") then return end
	for _, obj in zone:GetDescendants() do
		if obj:IsA("BasePart") then
			OriginalCFrames[obj] = obj.CFrame
		end
	end
end

local zonesFolder = workspace:WaitForChild("Zones")
for _, zone in zonesFolder:GetChildren() do
	SetupZone(zone)
end

zonesFolder.ChildAdded:Connect(SetupZone)
RunService.Heartbeat:Connect(UpdateKeys)
