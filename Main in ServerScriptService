local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Config = require(ReplicatedStorage:WaitForChild("Modules"):WaitForChild("Config"))

local TotalCharacters = #Config.Keys
local Randomizer = Random.new()

local function createZone(zoneNumber)
	local zonesFolder = workspace:FindFirstChild("Zones")
	if not zonesFolder then return end

	local zone = zonesFolder:FindFirstChild(tostring(zoneNumber))
	if not zone then return end

	local zoneData = Config.Zones[zoneNumber]
	if not zoneData then return end

	for _, key in zone:GetDescendants() do
		if not key:IsA("BasePart") then continue end

		local surfaceGui = key:FindFirstChildOfClass("SurfaceGui")
		local textLabel = surfaceGui and surfaceGui:FindFirstChildOfClass("TextLabel")
		if textLabel then
			textLabel.Text = Config.Keys[Randomizer:NextInteger(1, TotalCharacters)]
		end

		key.Color = zoneData.Colors[Randomizer:NextInteger(1, #zoneData.Colors)]
	end
end

local zonesFolder = workspace:WaitForChild("Zones")
for i in pairs(Config.Zones) do
	createZone(i)
end

zonesFolder.ChildAdded:Connect(function(child)
	local num = tonumber(child.Name)
	if num then
		createZone(num)
	end
end)
